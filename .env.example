# Copiá este archivo a `.env` y completá los valores.
# `.env` está git-ignored: NUNCA commitees claves reales.
# app.config.js carga estas variables vía `dotenv/config`.

# --- Google OAuth (IDs de cliente: son públicos por diseño, no son secretos) ---
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com
EXPO_PUBLIC_ANDROID_CLIENT_ID=your-android-oauth-client-id.apps.googleusercontent.com

# --- Google Maps SDK (Android) ---
# Esta key viaja dentro del APK (inevitable en Maps SDK for Android).
# Aségurala RESTRINGIÉNDOLA en Google Cloud: por package (com.sebit.castleapp) + SHA-1,
# y limitada a "Maps SDK for Android". Para builds en EAS, cargala como
# variable de entorno de EAS (no la pongas en eas.json).
GOOGLE_MAPS_API_KEY=your-restricted-android-maps-api-key

# --- Backend ---
REACT_APP_API_URL=https://castleapp-backend-production.up.railway.app
